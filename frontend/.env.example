# Auth0 (server + browser)
AUTH0_SECRET=use-openssl-rand-hex-32
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

NEXT_PUBLIC_AUTH0_DOMAIN=YOUR_TENANT.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=

# Upstream services (server-side BFF proxy). In Kubernetes use cluster DNS, e.g. http://energy-management:8080
ENERGY_SERVICE_URL=http://127.0.0.1:8080
VENDOR_SERVICE_URL=http://127.0.0.1:8081
IOT_SERVICE_URL=http://127.0.0.1:8082
AUTH_SERVICE_URL=http://127.0.0.1:8083
ML_SERVICE_URL=http://127.0.0.1:8084

# Optional: comma-separated origins for backend CORS (see backend CORS_ALLOWED_ORIGINS)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local dev service ports (next.config rewrites)
# DEV_ENERGY_URL=http://127.0.0.1:8080
# DEV_VENDOR_URL=http://127.0.0.1:8081
# DEV_IOT_URL=http://127.0.0.1:8082
# DEV_AUTH_URL=http://127.0.0.1:8083
# DEV_ML_URL=http://127.0.0.1:8084
